{
    "name": "WhatsArch",
    "short_name": "WhatsArch",
    "description": "Search your WhatsApp & Telegram chats with AI",
    "start_url": "/",
    "display": "standalone",
    "background_color": "#f8fafc",
    "theme_color": "#2563eb",
    "orientation": "any",
    "icons": [
        {
            "src": "/static/icon-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any maskable"
        },
        {
            "src": "/static/icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any maskable"
        }
    ],
    "share_target": {
        "action": "/api/upload/share",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "files": [
                {
                    "name": "shared-file",
                    "accept": [".zip", ".txt", ".json", "application/zip", "text/plain", "application/json"]
                }
            ]
        }
    }
}
