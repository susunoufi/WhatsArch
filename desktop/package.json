{
  "name": "whatsarch",
  "version": "1.0.0",
  "description": "WhatsArch - Multi-Platform Chat Archive Search Engine",
  "main": "main.js",
  "scripts": {
    "start": "node start.js",
    "setup-vendor": "node scripts/setup-vendor.js",
    "setup-vendor:mac-arm64": "node scripts/setup-vendor-mac.js --arch=arm64",
    "setup-vendor:mac-x64": "node scripts/setup-vendor-mac.js --arch=x64",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac-arm64": "electron-builder --mac --arm64",
    "build:mac-x64": "electron-builder --mac --x64",
    "build:mac-zip": "electron-builder --mac zip"
  },
  "author": "WhatsArch",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  },
  "build": {
    "appId": "com.whatsarch.app",
    "productName": "WhatsArch",
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "icon": "icons/icon.icns",
      "identity": null,
      "category": "public.app-category.productivity",
      "hardenedRuntime": false
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WhatsArch"
    },
    "extraResources": [
      {
        "from": "../run.py",
        "to": "app/run.py"
      },
      {
        "from": "../chat_search",
        "to": "app/chat_search",
        "filter": ["**/*", "!__pycache__/**"]
      },
      {
        "from": "../agent",
        "to": "app/agent",
        "filter": ["**/*", "!__pycache__/**", "!*.pyc"]
      },
      {
        "from": "../requirements.txt",
        "to": "app/requirements.txt"
      }
    ],
    "files": [
      "main.js",
      "start.js",
      "preload.js",
      "setup.html",
      "setup-preload.js",
      "icons/**",
      "node_modules/tree-kill/**",
      "!node_modules/electron",
      "!node_modules/electron/**",
      "!node_modules/electron-builder",
      "!node_modules/electron-builder/**",
      "!node_modules/.package-lock.json"
    ]
  }
}
