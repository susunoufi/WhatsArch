{
  "name": "whatsarch",
  "version": "1.0.0",
  "description": "WhatsArch - WhatsApp Chat Archive Search Engine",
  "main": "main.js",
  "scripts": {
    "start": "node start.js",
    "setup-vendor": "node scripts/setup-vendor.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "author": "WhatsArch",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  },
  "build": {
    "appId": "com.whatsarch.app",
    "productName": "WhatsArch",
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WhatsArch"
    },
    "extraResources": [
      {
        "from": "vendor/python",
        "to": "vendor/python",
        "filter": ["**/*"]
      },
      {
        "from": "vendor/ffmpeg",
        "to": "vendor/ffmpeg",
        "filter": ["**/*"]
      },
      {
        "from": "vendor/ollama",
        "to": "vendor/ollama",
        "filter": ["**/*"]
      },
      {
        "from": "../run.py",
        "to": "app/run.py"
      },
      {
        "from": "../chat_search",
        "to": "app/chat_search",
        "filter": ["**/*", "!__pycache__/**"]
      },
      {
        "from": "../requirements.txt",
        "to": "app/requirements.txt"
      }
    ],
    "files": [
      "main.js",
      "start.js",
      "preload.js",
      "setup.html",
      "setup-preload.js",
      "icons/**"
    ]
  }
}
