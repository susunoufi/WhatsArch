# WhatsArch Environment Variables
# Copy this file to .env and fill in your values

# --- AI Provider API Keys (at least one required for vision + RAG) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Supabase (required for cloud/web mode) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google OAuth (required for Google login in web mode) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
